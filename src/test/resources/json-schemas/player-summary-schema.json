{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["players"],
  "additionalProperties": false,
  "properties": {
    "players": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "age",
          "gender",
          "id",
          "screenName"
        ],
        "properties": {
          "age": {
            "type": "integer",
            "minimum": 0
          },
          "gender": {
            "type": "string"
          },
          "id": {
            "type": "integer",
            "minimum": 0
          },
          "screenName": {
            "type": "string"
          }
        }
      }
    }
  }
}